rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - displayName: string (required)
    //   - role: string (required, professional|client|admin)
    //   - photoURL: string (optional)
    //   - description: string (optional)
    //   - rating: number (optional)
    //   - reviewCount: number (optional)
    //   - createdAt: number (required)
    //   - plan: string (optional)
    //   - phone: string (optional)
    //   - location: string (optional)
    //
    // Collection: ads
    // Document ID: {adId}
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - imageUrl: string (optional)
    //   - sellerId: string (required)
    //   - sellerName: string (required)
    //   - sellerPhoto: string (optional)
    //   - status: string (required, active|completed)
    //   - createdAt: number (required)
    //   - location: map (optional)
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - id: string (required)
    //   - adId: string (required)
    //   - adTitle: string (optional)
    //   - reviewerId: string (required)
    //   - reviewerName: string (required)
    //   - reviewerPhoto: string (optional)
    //   - targetUserId: string (required)
    //   - rating: number (required)
    //   - comment: string (required)
    //   - createdAt: number (required)
    //
    // Collection: settings
    // Document ID: global | categories
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          request.auth.token.email == "VISARDF@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'displayName', 'role', 'createdAt']) &&
             data.uid is string &&
             data.username is string && data.username.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.role in ['professional', 'client', 'admin'] &&
             data.createdAt is number;
    }

    function isValidAd(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'price', 'category', 'sellerId', 'sellerName', 'status', 'createdAt']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.price is number &&
             data.category is string &&
             data.sellerId is string &&
             data.sellerName is string &&
             data.status in ['active', 'completed'] &&
             data.createdAt is number;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'adId', 'reviewerId', 'reviewerName', 'targetUserId', 'rating', 'comment', 'createdAt']) &&
             data.id is string &&
             data.adId is string &&
             data.reviewerId is string &&
             data.reviewerName is string &&
             data.targetUserId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if true; // Public profiles for marketplace
      allow create: if (isAuthenticated() && request.auth.uid == uid && isValidUser(request.resource.data) && request.resource.data.role != 'admin') || isAdmin();
      allow update: if (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if (isAuthenticated() && isValidAd(request.resource.data) && request.resource.data.sellerId == request.auth.uid) || isAdmin();
      allow update: if (isAuthenticated() && resource.data.sellerId == request.auth.uid && isValidAd(request.resource.data) && request.resource.data.sellerId == resource.data.sellerId) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.sellerId == request.auth.uid) || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if (isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.reviewerId == request.auth.uid) || isAdmin();
      allow update: if (isAuthenticated() && resource.data.reviewerId == request.auth.uid && isValidReview(request.resource.data) && request.resource.data.reviewerId == resource.data.reviewerId) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.reviewerId == request.auth.uid) || isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      // Allow creation of settings if they don't exist yet, or by admin
      allow create: if isAuthenticated(); 
      allow update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
