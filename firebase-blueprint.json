{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["professional", "client"] },
        "clientType": { "type": "string", "enum": ["architect", "engineer", "final_client", "real_estate", "construction_company", "condo", "commercial", "industrial"] },
        "photoURL": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "plan": { "type": "string", "enum": ["free", "premium"] },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "instagram": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "helperSpecialty": { "type": "string" }
      },
      "required": ["uid", "username", "displayName", "role", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "description": "Advertisement for services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "description", "category", "sellerId", "sellerName", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "User review for a service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "targetUserId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "adId", "reviewerId", "reviewerName", "targetUserId", "rating", "comment", "createdAt"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "appDescription": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "contactEmail": { "type": "string" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "globalAlert": { "type": "string" },
        "showLiveCounter": { "type": "boolean" },
        "liveCounterValue": { "type": "number" }
      },
      "required": ["appName", "appDescription", "maintenanceMode", "contactEmail", "primaryColor", "accentColor"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Collection of advertisements"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of reviews"
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application settings document"
    },
    "/settings/categories": {
      "schema": { "type": "object", "properties": { "list": { "type": "array", "items": { "type": "object" } } } },
      "description": "Custom categories list"
    }
  }
}
